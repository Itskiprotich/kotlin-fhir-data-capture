{
  "resourceType": "Questionnaire",
  "id": "template-extract-bundle-resource-repeating",
  "status": "active",
  "title": "Repeated Bundle resource extraction",
  "description": "Creates one extracted Bundle resource per repeated group iteration.",
  "contained": [
    {
      "resourceType": "Bundle",
      "id": "collectionTemplate",
      "type": "collection",
      "entry": [
        {
          "resource": {
            "resourceType": "Observation",
            "status": "final",
            "code": {
              "text": "Visit smoking status"
            },
            "_valueBoolean": {
              "extension": [
                {
                  "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-templateExtractValue",
                  "valueString": "item.where(linkId='smoker').answer.value.first()"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "item": [
    {
      "linkId": "visits",
      "text": "Visit bundles",
      "type": "group",
      "repeats": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-templateExtract",
          "extension": [
            {
              "url": "template",
              "valueReference": {
                "reference": "#collectionTemplate"
              }
            }
          ]
        }
      ],
      "item": [
        {
          "linkId": "smoker",
          "text": "Smoking status",
          "type": "boolean"
        }
      ]
    }
  ]
}
